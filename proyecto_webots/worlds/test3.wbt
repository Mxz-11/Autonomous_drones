WorldInfo {
  info [
    "Warehouse Search World — VLM Drone Navigation"
    "3 objetos con QR codes:"
    "  MEDKIT  -> caja blanca  en (X=5,  Y=2.5)"
    "  ZONE_A  -> pallet amarillo en (X=5,  Y=-2.5)"
    "  FRAGILE -> paquete naranja en (X=9,  Y=0)"
    "Prompts: Busca MEDKIT / Encuentra ZONE_A / Acercate a FRAGILE"
    "NOTA: coloca textures/qr_*.png junto al .wbt para ver los QR."
  ]
  title "Warehouse Search World"
  basicTimeStep 8
}
