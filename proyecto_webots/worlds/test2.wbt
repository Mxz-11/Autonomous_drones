WorldInfo {
  info [
    "Semantic Decision World — VLM Drone Navigation"
    "Almacen indoor con 3 objetos de color:"
    "  ROJO  -> bidon en (X=4, Y=2)"
    "  AZUL  -> caja en (X=4, Y=-2)"
    "  VERDE -> pallet en (X=8, Y=0)"
    "Prompts: Ve al bidon rojo / Busca la caja azul / Encuentra el pallet verde"
  ]
  title "Semantic Decision World"
  basicTimeStep 8
}
