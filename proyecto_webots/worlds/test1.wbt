WorldInfo {
  info [
    "VLM Drone Mission World."
    "Recorrido al aire libre con obstáculos físicos:"
    "  1. Despegar de la plataforma roja (X=0)."
    "  2. Pasar por el arco ROJO (X=4)."
    "  3. Rodear el bloque de contenedores por la derecha (X=7..9)."
    "  4. Pasar por el arco AZUL (X=12) entre muros de cajas."
    "  5. Zigzag entre conos (X=15..21)."
    "  6. Pasar por el arco VERDE (X=23)."
    "  7. Aterrizar en la plataforma verde con H (X=27)."
  ]
  title "VLM Drone Mission"
  basicTimeStep 8
}
